# Environment Configuration Example
# Copy this file to .env and adjust the values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Choose your database type: sqlite, db2, postgresql, mysql
DATABASE_TYPE=sqlite

# -----------------------------------------------------------------------------
# SQLite Configuration (Default for Development)
# -----------------------------------------------------------------------------
SQLITE_DATABASE=./cooking.db

# -----------------------------------------------------------------------------
# DB2 Configuration (Production)
# -----------------------------------------------------------------------------
DB2_HOST=localhost
DB2_PORT=50000
DB2_DATABASE=COOKDB
DB2_USER=db2inst1
DB2_PASSWORD=db2inst1-pwd

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (Optional)
# -----------------------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=cooking_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# MySQL Configuration (Optional)
# -----------------------------------------------------------------------------
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=cooking_db
# MYSQL_USER=root
# MYSQL_PASSWORD=root

# -----------------------------------------------------------------------------
# Database Connection Pool Settings
# -----------------------------------------------------------------------------
POOL_SIZE=10
MAX_OVERFLOW=20
POOL_PRE_PING=true

# Database Query Logging (set to true for debugging)
ECHO_SQL=false

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:3000

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_URL=http://localhost:8000

# =============================================================================
# DOCKER CONFIGURATION (Production)
# =============================================================================
# Uncomment these for Docker deployment
# VITE_API_URL=http://backend:8000
# CORS_ORIGINS=http://localhost,http://frontend
# DATABASE_TYPE=db2
# DB2_HOST=db2

# =============================================================================
# OPTIONAL CONFIGURATIONS
# =============================================================================

# File Upload Configuration
# MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
# UPLOAD_DIR=./uploads

# Security Configuration
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis Configuration (future)
# REDIS_URL=redis://localhost:6379