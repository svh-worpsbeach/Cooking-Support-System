# ============================================
# Cooking Management System - Configuration
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Choose your database type: sqlite, postgresql, db2, mysql
DATABASE_TYPE=sqlite

# --------------------------------------------
# SQLite Configuration (Default for Development)
# --------------------------------------------
SQLITE_DATABASE=./cooking.db

# --------------------------------------------
# PostgreSQL Configuration
# --------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5532
POSTGRES_DATABASE=cooking_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --------------------------------------------
# DB2 Configuration
# --------------------------------------------
DB2_HOST=localhost
DB2_PORT=5500
DB2_DATABASE=COOKDB
DB2_USER=db2inst1
DB2_PASSWORD=db2inst1-pwd

# --------------------------------------------
# MySQL Configuration
# --------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=cooking_db
MYSQL_USER=root
MYSQL_PASSWORD=root

# ============================================
# CONNECTION POOL SETTINGS
# ============================================
# These settings apply to PostgreSQL, DB2, and MySQL (not SQLite)
POOL_SIZE=10
MAX_OVERFLOW=20
POOL_PRE_PING=true

# ============================================
# LOGGING
# ============================================
# Set to true to see SQL queries in logs (useful for debugging)
ECHO_SQL=false

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5500,http://localhost:5501,http://localhost:5502,http://localhost:5580

# ============================================
# QUICK START EXAMPLES
# ============================================

# Example 1: Local Development with SQLite
# DATABASE_TYPE=sqlite
# SQLITE_DATABASE=./cooking.db

# Example 2: Docker with PostgreSQL
# DATABASE_TYPE=postgresql
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5532
# POSTGRES_DATABASE=cooking_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# Example 3: Docker with DB2
# DATABASE_TYPE=db2
# DB2_HOST=db2
# DB2_PORT=5500
# DB2_DATABASE=COOKDB
# DB2_USER=db2inst1
# DB2_PASSWORD=db2inst1-pwd

# Example 4: Production PostgreSQL
# DATABASE_TYPE=postgresql
# POSTGRES_HOST=your-postgres-server.com
# POSTGRES_PORT=5532
# POSTGRES_DATABASE=cooking_production
# POSTGRES_USER=cooking_user
# POSTGRES_PASSWORD=your-secure-password
# POOL_SIZE=20
# MAX_OVERFLOW=40
# POOL_PRE_PING=true